/* pages/memberAdd/memberAdd.wxss */
page {
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  padding: 32rpx;
}

.container {
  padding-bottom: 80rpx;
}

/* 卡片通用样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

/* 搜索卡片 */
.search-card {
  border-left: 6rpx solid #1677ff;
}

.search-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.search-input:focus {
  background: #ffffff;
  border-color: #1677ff;
}

/* 📷 OCR 识别按钮 */
.ocr-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.ocr-icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
}



/* 模糊搜索下拉列表 */
.dropdown-list {
  margin-top: 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
}

.dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #ebebeb;
  transition: background 0.2s;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: #e6f4ff;
}

.dropdown-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 2rpx;
}

.dropdown-owner {
  font-size: 24rpx;
  color: #666;
}

/* 无结果提示 */
.dropdown-empty {
  margin-top: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.dropdown-empty .empty-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 最近添加车辆 */
.recent-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.recent-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.recent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f0f5ff;
  border: 2rpx solid #d6e4ff;
  border-radius: 16rpx;
  min-width: 140rpx;
}

.recent-tag:active {
  background: #d6e4ff;
}

.recent-plate {
  font-size: 26rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 1rpx;
}

.recent-owner {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* 车辆信息卡片 */
.car-info-card {
  border-left: 6rpx solid #1677ff;
}

.re-search {
  margin-left: auto;
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 500;
}

.info-list {
  display: flex;
  flex-direction: column;
}

.info-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.info-value.plate-text {
  font-size: 32rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 2rpx;
}

.info-input {
  flex: 1;
  height: 72rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 10rpx;
  box-sizing: border-box;
  color: #333;
}

.info-input:focus {
  background: #ffffff;
  border-color: #1677ff;
}

/* 权益登记卡片 */
.benefit-card {
  border-left: 6rpx solid #722ed1;
}

.benefit-presets {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  margin-bottom: 24rpx;
}

.preset-tag {
  padding: 14rpx 24rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.preset-tag.active {
  background: linear-gradient(135deg, #722ed1 0%, #9254de 100%);
  border-color: #722ed1;
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(114, 46, 209, 0.3);
}

.benefit-fields {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field-row {
  display: flex;
  align-items: center;
}

.field-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 76rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #333;
}

.field-input:focus {
  background: #ffffff;
  border-color: #722ed1;
}

/* 备注卡片 */
.remark-card {
  border-left: 6rpx solid #faad14;
}

.remark-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

/* 按钮组 */
.button-group {
  display: flex;
  gap: 20rpx;
  padding-top: 80rpx;
  
}

.submit-btn {
  flex: 1;
  height: 88rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  opacity: 0.5;
  background: #d9d9d9;
  box-shadow: none;
}

.cancel-btn {
  flex: 1;
  height: 88rpx;
  background: #ffffff;
  color: #666;
  font-size: 32rpx;
  font-weight: 500;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0e0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}

.cancel-btn::after {
  border: none;
}

/* 添加权益按钮 */
.add-benefit-btn {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #f9f0ff;
  border: 2rpx dashed #b37feb;
  border-radius: 12rpx;
  text-align: center;
  color: #722ed1;
  font-size: 28rpx;
  font-weight: 500;
}

.add-benefit-btn:active {
  background: #efdbff;
}

/* 已添加权益列表 */
.added-benefit-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.added-benefit-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #f9f0ff;
  border-radius: 16rpx;
}

.added-benefit-left {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.added-benefit-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.added-benefit-count {
  font-size: 24rpx;
  color: #999;
}

.added-benefit-amount {
  font-size: 22rpx;
  color: #722ed1;
  margin-top: 2rpx;
}

.added-benefit-del {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ff4d4f;
  font-size: 28rpx;
  flex-shrink: 0;
}
