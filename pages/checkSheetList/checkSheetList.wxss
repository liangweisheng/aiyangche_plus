/* pages/checkSheetList/checkSheetList.wxss */
/* 复用 memberList 风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
  padding-bottom: 24rpx;
}

/* 搜索栏 */
.search-section {
  padding: 24rpx 24rpx 0;
}

.search-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
}

.clear-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.clear-icon {
  font-size: 22rpx;
  color: #999;
}

/* 统计卡片 */
.stats-section {
  padding: 20rpx 24rpx;
}

.stats-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 28rpx rgba(22, 119, 255, 0.3);
}

.stats-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 列表 */
.list-section {
  padding: 0 24rpx;
}

.sheet-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sheet-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.sheet-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.left-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plate {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 2rpx;
}

.owner-name {
  font-size: 24rpx;
  color: #666;
}

.date-badge {
  padding: 8rpx 20rpx;
  background: #f0f7ff;
  border-radius: 16rpx;
}

.date-text {
  font-size: 22rpx;
  color: #1677ff;
  font-weight: 600;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.car-type-text {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
}

/* 骨架屏 */
.skeleton-section {
  padding: 0 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.skeleton-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #f5f5f5 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-plate {
  width: 160rpx;
}

.skeleton-date {
  width: 120rpx;
}

.skeleton-sub {
  width: 240rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0 20rpx;
  text-align: center;
}

.load-more-text {
  font-size: 22rpx;
  color: #ccc;
}

.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0 20rpx;
}

.loading-dot {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 浮动首页按钮 */
.fab-home {
  position: fixed;
  right: 32rpx;
  bottom: 300rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.fab-home:active {
  opacity: 0.8;
  transform: scale(0.92);
}
