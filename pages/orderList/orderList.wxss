/* pages/orderList/orderList.wxss */
/* 商用SaaS风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
  padding-bottom: 280rpx;
}

/* ───────── 固定头部（搜索栏 + 统计 + 筛选） ───────── */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
}

/* 搜索栏 */
.search-section {
  padding: 24rpx 24rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.home-btn {
  flex-shrink: 0;
  padding: 20rpx 20rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #1677ff;
  white-space: nowrap;
  line-height: 1;
}

.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.search-wrapper:focus-within {
  box-shadow: 0 6rpx 28rpx rgba(22, 119, 255, 0.12);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
}

.clear-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.clear-icon {
  font-size: 28rpx;
  color: #999;
}

/* 📷 OCR 识别按钮 */
.ocr-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}
.ocr-icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

/* 统计卡片 */
.stats-section {
  padding: 20rpx 24rpx;
}

/* 筛选区域（独立于统计卡片，始终显示） */
.filter-section {
  padding: 0 24rpx;
  margin-bottom: 20rpx;
}

/* 状态筛选标签 */
.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.filter-tab {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s ease;
}

.filter-tab:active {
  transform: scale(0.96);
}

.filter-tab.active.style-working {
  background: #e6f4ff;
  color: #1677ff;
  border: 2rpx solid #91caff;
}

.filter-tab.active.style-pending {
  background: #fff7e6;
  color: #fa8c16;
  border: 2rpx solid #ffd591;
}

.filter-tab.active.style-done {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.stats-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 28rpx rgba(22, 119, 255, 0.25);
}

.stats-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 工单列表 */
.list-section {
  padding: 0 24rpx;
}

.order-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.order-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.order-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.plate {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 2rpx;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 会员标签 */
.member-badge {
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  background: #f9f0ff;
  color: #722ed1;
  font-size: 20rpx;
  font-weight: 600;
  border: 2rpx solid #d3adf7;
  flex-shrink: 0;
  margin-left: 8rpx;
}

.header-badges {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
}

/* 工单状态标签 */
.status-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.status-badge.status-done {
  background: #f6ffed;
  color: #52c41a;
  border: 2rpx solid #b7eb8f;
}

.status-badge.status-pending {
  background: #fff7e6;
  color: #fa8c16;
  border: 2rpx solid #ffd591;
}

.status-badge.status-working {
  background: #e6f4ff;
  color: #1677ff;
  border: 2rpx solid #91caff;
}

.pay-badge {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.pay-badge.pay-1 {
  background: rgba(22, 119, 255, 0.1);
  color: #1677ff;
}

.pay-badge.pay-2 {
  background: rgba(250, 173, 20, 0.1);
  color: #faad14;
}

.card-body {
  margin-bottom: 16rpx;
}

.service-text {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.card-footer {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.amount-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.amount-row {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 4rpx;
}

.amount-label {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

.amount-value {
  font-size: 26rpx;
  font-weight: 800;
  color: #1677ff;
}

.paid-label {
  font-size: 22rpx;
  color: #52c41a;
  white-space: nowrap;
}

.time-text {
  font-size: 20rpx;
  color: #ccc;
  flex-shrink: 0;
  white-space: nowrap;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 骨架屏 */
.skeleton-section {
  padding: 0 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #f5f5f5 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-plate {
  width: 120rpx;
  margin-bottom: 16rpx;
}

.skeleton-service {
  width: 300rpx;
  margin-bottom: 12rpx;
}

.skeleton-amount {
  width: 160rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 加载更多 */
.load-more {
  padding: 30rpx 0 20rpx;
  text-align: center;
}

.load-more-text {
  font-size: 22rpx;
  color: #ccc;
}

/* 加载更多loading */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0 20rpx;
}

.loading-dot {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 浮动新建按钮 */
.fab-add {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  height: 80rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.fab-add:active {
  opacity: 0.8;
  transform: scale(0.92);
}

/* 利润颜色 */
.amount-extra { font-size: 24rpx; }
.profit-positive { color: #22c55e; font-size: 24rpx; }
.profit-negative { color: #ef4444; font-size: 24rpx; }
