/* pages/memberList/memberList.wxss */
/* 商用SaaS风格 */

/* 游客模式横幅 */
.guest-banner {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  padding: 16rpx 32rpx;
  text-align: center;
}

.guest-banner-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
  padding-bottom: 280rpx;
  padding-bottom: calc(280rpx + env(safe-area-inset-bottom));
}

/* ───────── 固定头部（搜索栏 + 统计） ───────── */
.sticky-header {
  position: sticky;
  top: 0;
  z-index: 10;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
}

/* 搜索栏 */
.search-section {
  padding: 24rpx 24rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.home-btn {
  flex-shrink: 0;
  padding: 20rpx 20rpx;
  background: #f0f5ff;
  border-radius: 12rpx;
  font-size: 24rpx;
  color: #1677ff;
  white-space: nowrap;
  line-height: 1;
}

.search-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 24rpx;
  padding: 0 24rpx;
  height: 88rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.search-wrapper:focus-within {
  box-shadow: 0 6rpx 28rpx rgba(22, 119, 255, 0.12);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #333;
}

.search-placeholder {
  color: #bbb;
}

.clear-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.clear-icon {
  font-size: 28rpx;
  color: #999;
}

/* 📷 OCR 识别按钮 */
.ocr-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 8rpx;
}
.ocr-icon {
  width: 64rpx;
  height: 64rpx;
  display: block;
}

/* 统计卡片 */
.stats-section {
  padding: 20rpx 24rpx;
}

.stats-card {
  background: linear-gradient(135deg, #7c3aed 0%, #a78bfa 100%);
  border-radius: 20rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  box-shadow: 0 6rpx 28rpx rgba(124, 58, 237, 0.3);
}

.stats-num {
  font-size: 36rpx;
  font-weight: 800;
  color: #fff;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.member-limit-hint {
  margin-top: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff7e6;
  border-radius: 12rpx;
  text-align: center;
}

.member-limit-hint text {
  font-size: 24rpx;
  color: #d48806;
}

/* 会员列表 */
.list-section {
  padding: 0 24rpx;
}

.member-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.member-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
}

.member-card:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.08);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.left-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.plate {
  font-size: 32rpx;
  font-weight: 800;
  color: #333;
  letter-spacing: 2rpx;
}

.owner-name {
  font-size: 24rpx;
  color: #666;
}

.benefit-badge {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  background: linear-gradient(135deg, #722ed1 0%, #9254de 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(114, 46, 209, 0.25);
}

.benefit-name {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  font-weight: 500;
}

.benefit-count {
  font-size: 26rpx;
  font-weight: 800;
  color: #fff;
}

.no-benefit-tag {
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #bbb;
}

.benefit-badges {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.benefit-badges .benefit-badge {
  padding: 8rpx 16rpx;
}

.benefit-more {
  padding: 8rpx 16rpx;
  background: #f0e6ff;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #722ed1;
  font-weight: 600;
}

.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 16rpx;
  border-top: 1rpx solid #f5f5f5;
}

.phone {
  font-size: 24rpx;
  color: #999;
}

.arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 32rpx;
}

.empty-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #1677ff 0%, #0958d9 100%);
  padding: 16rpx 40rpx;
  border-radius: 32rpx;
  box-shadow: 0 6rpx 24rpx rgba(22, 119, 255, 0.3);
}

.empty-btn-icon {
  font-size: 28rpx;
  color: #fff;
  font-weight: 700;
}

.empty-btn-text {
  font-size: 28rpx;
  color: #fff;
  font-weight: 500;
}

/* 骨架屏 */
.skeleton-section {
  padding: 0 24rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.skeleton-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.skeleton-line {
  height: 24rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #f5f5f5 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 6rpx;
}

.skeleton-plate {
  width: 120rpx;
}

.skeleton-benefit {
  width: 100rpx;
}

.skeleton-phone {
  width: 200rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 加载更多 */
.load-more {
  padding: 40rpx 0 100rpx;
  text-align: center;
}

.load-more-text {
  font-size: 24rpx;
  color: #bbb;
}

/* 加载更多loading */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 30rpx 0 20rpx;
}

.loading-dot {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #e0e0e0;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.6s linear infinite;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* 浮动添加按钮 */
.fab-add {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  height: 80rpx;
  padding: 0 32rpx;
  border-radius: 40rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.fab-add:active {
  opacity: 0.8;
  transform: scale(0.92);
}
