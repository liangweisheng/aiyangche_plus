<!-- 会员列表 - 商用SaaS风格 -->
<wxs src="../../utils/maskPlate.wxs" module="mask" />
<view class="container">

  <view class="sticky-header">
  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="home-btn" bindtap="onGoHome">
      <text>🏠首页</text>
    </view>
    <view class="search-wrapper">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索车牌号、车主姓名或手机号"
        placeholder-class="search-placeholder"
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="clear-btn" wx:if="{{searchKeyword}}" bindtap="onClearSearch">
        <text class="clear-icon">✕</text>
      </view>
      <view class="ocr-btn" bindtap="onScanPlate">
        <image class="ocr-icon" src="/images/camera.png" mode="aspectFit" />
      </view>
    </view>
  </view>

  <!-- 统计信息 -->
  <view class="stats-section" wx:if="{{!loading && !isEmpty && memberList.length > 0}}">
    <view class="stats-card">
      <text class="stats-num">{{totalCount}}</text>
      <text class="stats-label">会员总数{{!isPro ? '（' + totalCount + '/' + freeMaxMembers + '）' : ''}}</text>
    </view>
    <view class="member-limit-hint" wx:if="{{memberLimitReached && !isPro}}" bindtap="goToPro">
      <text>⚠️ 免费版会员已达上限，升级Pro版 ›</text>
    </view>
  </view>
  </view>

  <!-- 游客模式提示（放 sticky 区域外，随列表滚动） -->
  <view class="guest-banner" wx:if="{{isGuest}}">
    <text class="guest-banner-text">当前为游客模式，数据仅为演示</text>
  </view>

  <!-- 会员列表 -->
  <view class="list-section">
    <view class="member-list" wx:if="{{memberList.length > 0}}">
      <view
        class="member-card"
        wx:for="{{memberList}}"
        wx:key="_id"
        data-id="{{item._id}}"
        data-plate="{{item.plate}}"
        bindtap="onMemberTap"
      >
        <view class="card-header">
          <view class="left-info">
            <text class="plate">{{mask.maskPlate(item.plate)}}</text>
            <text class="owner-name">{{item.ownerName}}</text>
          </view>
          <view class="benefit-badges" wx:if="{{item.benefits && item.benefits.length > 0 || item.benefitName}}">
            <view class="benefit-badge" wx:for="{{(item.benefits && item.benefits.length > 0) ? item.benefits : [{name: item.benefitName, remain: item.benefitRemain || 0}]}}" wx:for-item="b" wx:for-index="bi" wx:key="bi" wx:if="{{bi < 2}}">
              <text class="benefit-name">{{b.name}}</text>
              <text class="benefit-count">剩{{b.remain || 0}}次</text>
            </view>
            <view class="benefit-more" wx:if="{{item.benefits && item.benefits.length > 2}}">+{{item.benefits.length - 2}}</view>
          </view>
          <view class="no-benefit-tag" wx:elif="{{!item.benefitName && (!item.benefits || item.benefits.length === 0)}}">
            <text>未登记权益</text>
          </view>
        </view>
        <view class="card-footer">
          <text class="phone">{{item.phoneMasked}}</text>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{isEmpty && !loading}}">
      <text class="empty-icon">👤</text>
      <text class="empty-text">暂无会员，请点击添加会员</text>
      <view class="empty-btn" bindtap="onAddMember">
        <text class="empty-btn-icon">+</text>
        <text class="empty-btn-text">添加会员</text>
      </view>
    </view>

    <!-- 加载更多 / 没有更多 -->
    <view class="load-more" wx:if="{{memberList.length > 0 && !loading}}">
      <text class="load-more-text" wx:if="{{noMore}}">— 已加载全部 {{memberList.length}} 条 —</text>
      <text class="load-more-text" wx:else>上拉加载更多</text>
    </view>
  </view>

  <!-- 加载骨架（仅首次加载） -->
  <view class="skeleton-section" wx:if="{{loading && memberList.length === 0}}">
    <view class="skeleton-card">
      <view class="skeleton-header">
        <view class="skeleton-line skeleton-plate"></view>
        <view class="skeleton-line skeleton-benefit"></view>
      </view>
      <view class="skeleton-line skeleton-phone"></view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-header">
        <view class="skeleton-line skeleton-plate"></view>
        <view class="skeleton-line skeleton-benefit"></view>
      </view>
      <view class="skeleton-line skeleton-phone"></view>
    </view>
    <view class="skeleton-card">
      <view class="skeleton-header">
        <view class="skeleton-line skeleton-plate"></view>
        <view class="skeleton-line skeleton-benefit"></view>
      </view>
      <view class="skeleton-line skeleton-phone"></view>
    </view>
  </view>

  <!-- 加载更多loading -->
  <view class="loading-more" wx:if="{{loading && memberList.length > 0}}">
    <view class="loading-dot"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 浮动添加会员按钮 -->
  <view class="fab-add" bindtap="onAddMember">＋会员</view>

  <!-- 隐藏Canvas：用于生成分享卡片 -->
  <canvas type="2d" id="shareCanvas" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:400px;"></canvas>
  <canvas canvas-id="shareCanvasFallback" style="position:fixed;left:-9999px;top:-9999px;width:500px;height:400px;"></canvas>

</view>

