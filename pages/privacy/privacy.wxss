.policy-container {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.policy-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 12rpx;
}

.policy-update {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 32rpx;
}

.policy-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 24rpx;
}

.section-head {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
}

.section-body {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.text-block {
  display: block;
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #444;
  margin: 16rpx 0 8rpx;
}

.important {
  color: #1677ff;
  font-weight: 500;
}

.important-section {
  color: #1677ff;
  font-size: 32rpx;
}
