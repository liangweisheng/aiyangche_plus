.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
  overflow: hidden;
}

/* ====== 固定表头 ====== */
.sticky-header {
  flex-shrink: 0;
  background: #fff;
}

/* ====== 搜索框 ====== */
.search-bar {
  padding: 20rpx 24rpx;
  background: #fff;
}
.search-input {
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 32rpx;
  font-size: 28rpx;
  color: #333;
}

/* ====== 分类标签 ====== */
.category-scroll {
  white-space: nowrap;
  background: #fff;
  padding: 0 24rpx 16rpx;
}
.category-list {
  display: inline-flex;
  gap: 16rpx;
}
.category-tag {
  display: inline-block;
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}
.category-tag.active {
  color: #ff4d4f;
  background: #fff0f0;
  font-weight: 500;
}

/* ====== 导入状态筛选（第2行） ====== */
.status-filter-row {
  display: flex;
  gap: 16rpx;
  background: #fff;
  padding: 4rpx 24rpx 16rpx;
  flex-wrap: wrap;
}
.status-filter-tag {
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f5f5;
  transition: all 0.2s;
}
.status-filter-tag.active {
  color: #1677ff;
  background: #e6f0ff;
  font-weight: 500;
}

/* 创建模板商品按钮 */
.create-template-btn {
  padding: 8rpx 24rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  background: #52c41a;
  color: #fff;
  font-weight: 500;
  transition: all 0.2s;
  white-space: nowrap;
  margin-left: auto;
}
.create-template-btn:active {
  opacity: 0.8;
}

/* ====== 可滚动列表区 ====== */
.scroll-area {
  flex: 1;
  min-height: 0;
  padding: 16rpx 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

/* ====== 加载中（旋转动画） ====== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}
.loading-spinner {
  width: 56rpx;
  height: 56rpx;
  border: 6rpx solid #e6f0ff;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* ====== 模板列表 ====== */
.template-list {
  /* padding 由 .scroll-area 统一提供 */
}
.template-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  transition: all 0.2s;
}
.template-item.selected {
  background: #f0f7ff;
}
.template-item.imported {
  background: #f7f7f7;
  opacity: 0.65;
}
.template-item.imported .template-name {
  color: #999;
}
.template-info {
  flex: 1;
  min-width: 0;
}
.template-name-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 8rpx;
}
.template-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}
.template-category-tag {
  font-size: 16rpx;
  color: #1677ff;
  background: #e6f0ff;
  padding: 1rpx 8rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
/* 排序号标签 */
.template-sortorder-tag {
  font-size: 16rpx;
  color: #999;
  background: #f5f5f5;
  padding: 1rpx 8rpx;
  border-radius: 6rpx;
  white-space: nowrap;
  flex-shrink: 0;
}
.template-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 4rpx;
}
.template-price {
  color: #ff4d4f;
  font-weight: 500;
}
.template-specs {
  color: #666;
}
/* ====== 操作按钮 ====== */
.template-action {
  flex-shrink: 0;
  margin-left: 20rpx;
}
.status-toggle {
  min-width: 110rpx;
  height: 52rpx;
  line-height: 52rpx;
  text-align: center;
  border-radius: 26rpx;
  font-size: 24rpx;
  font-weight: 500;
  color: #1677ff;
  border: 1px solid #1677ff;
  background: #fff;
}
.status-toggle.on {
  background: #e6f0ff;
  color: #1677ff;
  border: 1px solid #1677ff;
}
.status-toggle.off {
  background: #f5f5f5;
  color: #999;
  border: 1px solid #ddd;
}
.status-toggle.imported {
  color: #999;
  border: 1px solid #ccc;
  background: #f5f5f5;
}

/* ====== 空状态 ====== */
.empty-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 40rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 16rpx;
}
.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  text-align: center;
}

/* ====== 加载更多 ====== */
.load-more-wrap {
  padding: 20rpx 0 40rpx;
}
.load-more-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 26rpx;
  color: #999;
  padding: 16rpx 0;
}
.load-more-tap {
  color: #1677ff;
}
.load-more-tap:active {
  opacity: 0.7;
}
.load-more-done {
  color: #bbb;
}
.load-more-spinner {
  width: 28rpx;
  height: 28rpx;
  border: 4rpx solid #e6f0ff;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}
.load-more-text {
  font-size: 26rpx;
}

/* ====== 底部操作栏 ====== */
.batch-bar {
  flex-shrink: 0;
  padding: 20rpx 24rpx 40rpx;
  background: #fff;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.06);
}
.batch-row {
  display: flex;
  gap: 20rpx;
}
.batch-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  padding: 0;
  border: none;
}
.batch-btn-primary {
  background: #1677ff;
  color: #fff;
}
.batch-btn-primary[disabled] {
  opacity: 0.6;
}
.batch-btn-secondary {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
}
.batch-btn-secondary:active {
  background: #f0f5ff;
}

/* ====== 复选框样式 ====== */
.template-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  border: 2rpx solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}
.template-checkbox.checked {
  border-color: #1677ff;
  background: #1677ff;
}
.template-checkbox.checked .checkbox-inner {
  width: 16rpx;
  height: 24rpx;
  border: 2rpx solid #fff;
  border-top: none;
  border-left: none;
  transform: rotate(45deg) translate(-2rpx, -4rpx);
}

/* ====== 全选区域 ====== */
.select-all {
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  height: 88rpx;
}
.select-all .template-checkbox {
  margin-right: 8rpx;
}
.select-all-text {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
}
.batch-left {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

/* ====== 规格标签布局 ====== */
.spec-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
  max-height: 64rpx;
  overflow: hidden;
}
.spec-tag {
  display: inline-block;
  padding: 4rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 22rpx;
  color: #666;
  white-space: nowrap;
}

/* ====== 编辑按钮 ====== */
.edit-btn {
  min-width: 80rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #1677ff;
  background: #f0f5ff;
  margin-top: 8rpx;
  border: 1px solid #1677ff;
}
.edit-btn:active {
  opacity: 0.7;
}
