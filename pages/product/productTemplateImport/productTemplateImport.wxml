<view class="container">
  <!-- 固定表头（搜索+分类+筛选） -->
  <view class="sticky-header">
    <!-- 搜索框 -->
    <view class="search-bar">
      <input class="search-input" type="text" placeholder="搜索模板商品" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
    </view>

    <!-- 分类标签 -->
    <scroll-view class="category-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="category-list">
        <view
          class="category-tag {{currentCategory === item ? 'active' : ''}}"
          wx:for="{{categoryOptions}}" wx:key="*this"
          data-cat="{{item}}"
          bindtap="onCategoryTap"
        >{{item}}</view>
      </view>
    </scroll-view>

    <!-- 导入状态筛选（第2行） -->
    <view class="status-filter-row">
      <view
        class="status-filter-tag {{importStatusFilter === '' ? 'active' : ''}}"
        data-status=""
        bindtap="onImportStatusTap"
      >全部</view>
      <view
        class="status-filter-tag {{importStatusFilter === 'imported' ? 'active' : ''}}"
        data-status="imported"
        bindtap="onImportStatusTap"
      >已导入</view>
      <view
        class="status-filter-tag {{importStatusFilter === 'notImported' ? 'active' : ''}}"
        data-status="notImported"
        bindtap="onImportStatusTap"
      >未导入</view>
      <view class="create-template-btn" bindtap="onGoCreateTemplate">+ 创建模板商品</view>
    </view>
  </view>

  <!-- 可滚动列表区 -->
  <scroll-view class="scroll-area" scroll-y bindscrolltolower="loadMore" enhanced>
    <!-- 首次加载中 -->
    <view class="loading-wrap" wx:if="{{loading && allLoadedTemplates.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">正在加载模板数据...</text>
    </view>

    <!-- 模板列表 -->
    <view class="template-list" wx:if="{{!loading && templateList.length > 0}}">
      <view class="template-item {{selectedIds[item._id] ? 'selected' : ''}}{{item.isImported ? ' imported' : ''}}" wx:for="{{templateList}}" wx:key="_id" data-id="{{item._id}}">
        <!-- 复选框 -->
        <view class="template-checkbox {{selectedIds[item._id] ? 'checked' : ''}}" bindtap="onToggleSelect" data-id="{{item._id}}">
          <view class="checkbox-inner"></view>
        </view>
        <view class="template-info">
          <view class="template-name-row">
            <text class="template-name">{{item.name}}</text>
            <text class="template-category-tag">{{item.category}}</text>
            <text class="template-sortorder-tag">#{{item.sortOrder}}</text>
          </view>
          <!-- 规格标签 -->
          <view class="spec-tags" wx:if="{{item.specs && item.specs.length > 0}}">
            <text class="spec-tag" wx:for="{{item.specs}}" wx:for-index="sidx" wx:key="sidx">{{item}}</text>
          </view>
        </view>
        <view class="template-action">
          <view class="status-toggle {{item.isImported ? 'imported' : ''}}" data-id="{{item._id}}" bindtap="{{item.isImported ? '' : 'onImportTemplate'}}">
            <text wx:if="{{item.importing}}">...</text>
            <text wx:elif="{{item.isImported}}">已导入</text>
            <text wx:else>导入</text>
          </view>
          <view class="edit-btn" data-id="{{item._id}}" bindtap="onEditTemplate">编辑</view>
        </view>
      </view>
    </view>

    <!-- 加载更多指示 -->
    <view class="load-more-wrap" wx:if="{{!loading && allLoadedTemplates.length > 0}}">
      <view class="load-more-hint" wx:if="{{loadingPage}}">
        <view class="load-more-spinner"></view>
        <text class="load-more-text">加载中...</text>
      </view>
      <view class="load-more-hint load-more-tap" wx:elif="{{hasMore}}" bindtap="loadMore">
        <text class="load-more-text">点击加载更多（{{allLoadedTemplates.length}}/{{totalCount}}）</text>
      </view>
      <view class="load-more-hint load-more-done" wx:else>
        <text>已加载全部 {{totalCount}} 条</text>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-wrap" wx:if="{{!loading && allLoadedTemplates.length === 0 && !loadingPage}}">
      <text class="empty-text">暂无模板商品</text>
      <text class="empty-hint">可先在"新建商品"中添加常用商品，联系客服同步到模板库</text>
    </view>

    <!-- 过滤后无结果的空提示 -->
    <view class="empty-wrap" wx:elif="{{!loading && allLoadedTemplates.length > 0 && templateList.length === 0}}">
      <text class="empty-text">当前筛选条件下无结果</text>
      <text class="empty-hint">试试切换筛选条件或加载更多数据</text>
    </view>
  </scroll-view>

  <!-- 底部操作栏 -->
  <view class="batch-bar" wx:if="{{!loading}}">
    <view class="batch-row">
      <view class="batch-left">
        <view class="select-all" bindtap="onSelectAllTap">
          <view class="template-checkbox {{allSelected ? 'checked' : ''}}">
            <view class="checkbox-inner"></view>
          </view>
          <text class="select-all-text">{{allSelected ? '取消全选' : '全选'}}</text>
        </view>
      </view>
      <button class="batch-btn batch-btn-secondary" bindtap="onGoProductAdd">新建自定义商品</button>
      <button class="batch-btn batch-btn-primary" bindtap="onBatchImport" disabled="{{batchLoading || selectedCount === 0}}">
        {{batchLoading ? '导入中...' : '批量导入模板商品' + (selectedCount > 0 ? '（' + selectedCount + '）' : '')}}
      </button>
    </view>
  </view>
</view>
