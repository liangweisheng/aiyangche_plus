/* pages/product/productAdd/productAdd.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.form-group {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.form-label-row .form-label {
  margin-bottom: 0;
}

.required {
  color: #ff4d4f;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-picker {
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  display: flex;
  align-items: center;
}

.form-picker.placeholder {
  color: #bbb;
}

.form-textarea {
  width: 100%;
  height: 160rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.form-tip {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

.form-add-spec {
  font-size: 26rpx;
  color: #1677ff;
  padding: 8rpx 16rpx;
  background: rgba(22,119,255,0.06);
  border-radius: 8rpx;
}

/* 规格表格 */
.spec-table {
  margin-top: 8rpx;
  border: 2rpx solid #e8e8e8;
  border-radius: 12rpx;
  overflow: hidden;
}

.spec-table-header {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  padding: 16rpx 12rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.spec-table-header .spec-col-name {
  flex: 2;
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
  text-align: center;
}

.spec-table-header .spec-col-cost,
.spec-table-header .spec-col-price {
  flex: 1;
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
  text-align: center;
}

.spec-table-header .spec-col-del {
  width: 48rpx;
  flex-shrink: 0;
}

.spec-table-row {
  display: flex;
  align-items: center;
  padding: 12rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.spec-table-row:last-child {
  border-bottom: none;
}

.spec-table-row .spec-col-name {
  flex: 2;
  height: 64rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  color: #333;
  margin-right: 8rpx;
}

.spec-table-row .spec-col-cost {
  flex: 1;
  height: 64rpx;
  background: #fff7e6;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  color: #fa8c16;
  text-align: center;
  margin-right: 8rpx;
}

.spec-table-row .spec-col-price {
  flex: 1;
  height: 64rpx;
  background: #fff0f0;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 24rpx;
  color: #ff4d4f;
  text-align: center;
  margin-right: 8rpx;
}

.spec-col-del {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff0f0;
  border-radius: 50%;
  font-size: 24rpx;
  color: #ff4d4f;
  flex-shrink: 0;
}

.spec-col-del:active {
  background: #ffd6d6;
}

/* 多规格折叠区 */
.spec-collapse {
  border: 2rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 0;
  overflow: hidden;
}

.spec-collapse-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  background: #fafafa;
  min-height: 48rpx;
}

.spec-collapse-header:active {
  background: #f0f0f0;
}

.spec-arrow {
  font-size: 28rpx;
  color: #999;
  transition: transform 0.2s ease;
  display: inline-block;
}

.spec-arrow-up {
  transform: rotate(90deg);
}

.spec-collapse-body {
  padding: 0 24rpx 24rpx;
  display: none;
}

.spec-collapse-open {
  display: block;
}

.spec-collapse-actions {
  display: flex;
  justify-content: flex-end;
  margin-top: 16rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}

.save-btn[disabled] {
  opacity: 0.6;
}

.save-btn::after { border: none; }
