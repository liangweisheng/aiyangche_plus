/* pages/product/productDetail/productDetail.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
}

.info-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.product-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.product-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
}

.product-cat-tag {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  background: #f0f7ff;
  color: #1677ff;
  border-radius: 6rpx;
}

.info-rows { display: flex; flex-direction: column; gap: 16rpx; }

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.info-value.price {
  color: #ff4d4f;
  font-size: 34rpx;
}

.info-value.stock {
  color: #1677ff;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #999;
  margin-bottom: 16rpx;
  margin-top: 8rpx;
}

.log-list {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
}

.log-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.log-item:last-child { border-bottom: none; }

.log-type-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.log-type {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 600;
}

.log-type.type-in {
  background: #f6ffed;
  color: #52c41a;
}

.log-type.type-out {
  background: #fff2f0;
  color: #ff4d4f;
}

.log-spec {
  font-size: 24rpx;
  color: #999;
}

.log-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.log-qty {
  font-weight: 700;
}

.log-cost {
  color: #999;
}

.log-time {
  color: #bbb;
  margin-left: auto;
}

.log-remark {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 4rpx;
}

.log-empty, .log-loading {
  text-align: center;
  padding: 40rpx 0;
  font-size: 26rpx;
  color: #bbb;
}
