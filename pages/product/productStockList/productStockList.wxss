/* pages/product/productStockList/productStockList.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
}

.search-bar {
  margin-bottom: 16rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 76rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.search-icon { font-size: 28rpx; margin-right: 12rpx; flex-shrink: 0; }
.search-input { flex: 1; height: 76rpx; font-size: 28rpx; color: #333; }
.search-clear { font-size: 28rpx; color: #ccc; padding: 8rpx; flex-shrink: 0; }
.search-clear:active { color: #999; }

.category-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  gap: 12rpx;
  padding: 8rpx 0;
}

.category-tag {
  display: inline-block;
  padding: 10rpx 24rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #666;
  border: 2rpx solid #eee;
}

.category-tag.active {
  background: #1677ff;
  color: #fff;
  border-color: #1677ff;
}

.product-list {
  padding-bottom: 40rpx;
}

.product-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.04);
}

.product-item:active {
  transform: scale(0.98);
}

.product-info { flex: 1; min-width: 0; }

.product-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 10rpx;
}

.product-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.product-cat-tag {
  font-size: 20rpx;
  padding: 2rpx 12rpx;
  background: #f0f7ff;
  color: #1677ff;
  border-radius: 6rpx;
}

.product-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.product-specs {
  font-size: 24rpx;
  color: #999;
}

.product-price {
  font-size: 26rpx;
  color: #ff4d4f;
  font-weight: 600;
}

.product-stock-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.product-stock {
  font-size: 24rpx;
  color: #666;
}

.product-cost {
  font-size: 22rpx;
  color: #bbb;
}

.product-arrow {
  font-size: 32rpx;
  color: #ccc;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.empty-state, .loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon { font-size: 72rpx; opacity: 0.3; margin-bottom: 16rpx; }
.empty-text { font-size: 28rpx; color: #bbb; }
.loading-state { font-size: 26rpx; color: #999; }
