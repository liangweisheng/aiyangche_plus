<view class="container">
  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品名称" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
      <text class="search-clear" wx:if="{{keyword}}" bindtap="onClearSearch">✕</text>
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-tag {{currentCategory === item ? 'active' : ''}}" wx:for="{{categoryOptions}}" wx:key="item" data-cat="{{item}}" bindtap="onCategoryTap">{{item}}</view>
    </view>
  </scroll-view>

  <!-- 列表 -->
  <view class="product-list">
    <view class="product-item" wx:for="{{productList}}" wx:key="_id" data-id="{{item._id}}" bindtap="onGoDetail">
      <view class="product-info">
        <view class="product-name-row">
          <text class="product-name">{{item.name}}</text>
          <text class="product-cat-tag">{{item.category}}</text>
        </view>
        <view class="product-meta">
          <text class="product-specs" wx:if="{{item.specs && item.specs.length > 0}}">{{item.specs.join('、')}}</text>
          <text class="product-price">¥{{item.price}}/{{item.unit}}</text>
        </view>
        <view class="product-stock-row">
          <text class="product-stock">库存：{{item.stock || 0}}{{item.unit}}</text>
          <text class="product-cost" wx:if="{{item.cost > 0}}">进价：¥{{item.cost}}</text>
        </view>
      </view>
      <text class="product-arrow">›</text>
    </view>
    <view class="empty-state" wx:if="{{productList.length === 0 && !loading}}">
      <text class="empty-icon">📦</text>
      <text class="empty-text">暂无商品</text>
    </view>
    <view class="loading-state" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
  </view>
</view>
