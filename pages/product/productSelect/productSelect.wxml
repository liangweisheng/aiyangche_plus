<view class="container">
  <!-- 左侧分类栏 -->
  <scroll-view class="category-sidebar" scroll-y>
    <view class="cat-item {{currentCategory === item ? 'active' : ''}}" wx:for="{{categoryOptions}}" wx:key="item" data-cat="{{item}}" bindtap="onCategoryTap">{{item}}</view>
  </scroll-view>

  <!-- 右侧商品列表 -->
  <view class="product-main">
    <!-- 搜索 -->
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索商品" value="{{keyword}}" bindinput="onSearchInput" confirm-type="search" />
    </view>

    <!-- 商品列表 -->
    <scroll-view class="product-scroll" scroll-y>
      <view class="product-list">
        <view class="product-card" wx:for="{{productList}}" wx:key="_id">
          <!-- 商品名 -->
          <text class="product-card-name">{{item.name}}</text>
          <!-- 规格行 -->
          <view class="spec-row" wx:for="{{item.displaySpecs}}" wx:for-item="spec" wx:key="index">
            <text class="spec-label">{{spec.label}}</text>
            <view class="spec-qty-control">
              <text class="qty-btn qty-minus" data-pid="{{item._id}}" data-spec="{{spec.label}}" data-delta="{{-1}}" bindtap="onQtyChange">−</text>
              <text class="qty-num">{{spec.quantity > 0 ? spec.quantity : '0'}}</text>
              <text class="qty-btn qty-plus" data-pid="{{item._id}}" data-spec="{{spec.label}}" data-delta="{{1}}" bindtap="onQtyChange">+</text>
            </view>
          </view>
          <!-- 无规格展示 -->
          <view class="spec-row" wx:if="{{!item.specs || item.specs.length === 0}}">
            <text class="spec-label">¥{{item.price}}/{{item.unit}}</text>
            <view class="spec-qty-control">
              <text class="qty-btn qty-minus" data-pid="{{item._id}}" data-spec="" data-delta="{{-1}}" bindtap="onQtyChange">−</text>
              <text class="qty-num">{{item._qty > 0 ? item._qty : '0'}}</text>
              <text class="qty-btn qty-plus" data-pid="{{item._id}}" data-spec="" data-delta="{{1}}" bindtap="onQtyChange">+</text>
            </view>
          </view>
        </view>

        <view class="empty-state" wx:if="{{productList.length === 0 && !loading}}">
          <text class="empty-icon">📦</text>
          <text class="empty-text">暂无商品</text>
        </view>
        <view class="loading-state" wx:if="{{loading}}">
          <text>加载中...</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 底部确认栏 -->
  <view class="bottom-bar" wx:if="{{selectedItems.length > 0}}">
    <text class="bar-summary">已选 {{selectedItems.length}} 件</text>
    <text class="bar-total">合计：¥{{totalAmount}}</text>
    <button class="bar-btn" bindtap="onConfirm">确定</button>
  </view>
</view>
