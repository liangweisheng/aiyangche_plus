/* pages/product/productStockIn/productStockIn.wxss */
.container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx;
  padding-bottom: 160rpx;
}

/* ===== 选择按钮 ===== */
.section-header {
  margin-bottom: 20rpx;
}

.select-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}
.select-btn::after { border: none; }

/* ===== 空态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ===== 表格卡片 ===== */
.table-card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  overflow: hidden;
  margin-bottom: 20rpx;
}

.table-header {
  display: flex;
  background: #f0f5ff;
  padding: 20rpx 16rpx;
  border-bottom: 2rpx solid #e8e8e8;
}

.th {
  font-size: 24rpx;
  color: #666;
  font-weight: 600;
  text-align: center;
}

/* 列宽分配 */
.th-name, .td-name { flex: 2.5; text-align: left; }
.th-spec, .td-spec { flex: 1.5; text-align: left; }
.th-qty, .td-qty { flex: 1.2; text-align: center; }
.th-cost, .td-cost { flex: 1.2; text-align: center; }
.th-action, .td-action { flex: 0.6; text-align: center; }

.table-body {
  max-height: 600rpx;
  overflow-y: auto;
}

.table-row {
  display: flex;
  align-items: center;
  padding: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
}
.table-row:last-child { border-bottom: none; }

.td {
  font-size: 26rpx;
  color: #333;
}

.td-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.td-spec {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ===== 进价输入框 ===== */
.cost-input {
  width: 120rpx;
  height: 56rpx;
  background: #f7f8fa;
  border-radius: 8rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  color: #333;
  text-align: center;
  display: inline-block;
}

.cost-input::-webkit-input-placeholder {
  font-size: 22rpx;
  color: #ccc;
}

/* ===== 删除按钮 ===== */
.del-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 44rpx;
  height: 44rpx;
  background: #fff1f0;
  border-radius: 50%;
  color: #ff4d4f;
  font-size: 24rpx;
}

/* ===== 底部信息表单 ===== */
.form-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.form-group {
  margin-bottom: 28rpx;
}
.form-group:last-child { margin-bottom: 0; }

.form-label {
  display: block;
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 72rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

/* ===== 底部按钮 ===== */
.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 24rpx rgba(0,0,0,0.06);
}

.save-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  border-radius: 44rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
  border: none;
}

.save-btn[disabled] { opacity: 0.6; }
.save-btn::after { border: none; }
