<view class="container">
  <view class="section-header">
    <button class="select-btn" bindtap="onSelectProducts">+ 批量选择商品</button>
  </view>

  <!-- 空态 -->
  <view class="empty-state" wx:if="{{selectedItems.length === 0}}">
    <image class="empty-icon" src="/images/empty-box.png" mode="aspectFit" />
    <text class="empty-text">请点击上方按钮选择商品</text>
  </view>

  <!-- 商品表格 -->
  <view class="table-card" wx:if="{{selectedItems.length > 0}}">
    <view class="table-header">
      <text class="th th-name">商品名称</text>
      <text class="th th-spec">规格</text>
      <text class="th th-qty">数量</text>
      <text class="th th-cost">进价</text>
      <text class="th th-action">操作</text>
    </view>
    <view class="table-body">
      <view class="table-row" wx:for="{{selectedItems}}" wx:for-index="idx" wx:key="_rowKey">
        <text class="td td-name">{{item.name}}</text>
        <text class="td td-spec">{{item.spec || '无规格'}}</text>
        <text class="td td-qty">{{item.quantity}} {{item.unit}}</text>
        <view class="td td-cost">
          <input class="cost-input" type="digit" placeholder="进价"
            value="{{item.cost}}"
            data-index="{{idx}}"
            bindinput="onCostInput" />
        </view>
        <view class="td td-action">
          <text class="del-btn" data-index="{{idx}}" bindtap="onRemoveItem">✕</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="form-card" wx:if="{{selectedItems.length > 0}}">
    <view class="form-group">
      <text class="form-label">供货商</text>
      <input class="form-input" type="text" placeholder="选填" value="{{supplier}}" bindinput="onInput" data-field="supplier" />
    </view>
    <view class="form-group">
      <text class="form-label">备注</text>
      <input class="form-input" type="text" placeholder="选填" value="{{remark}}" bindinput="onInput" data-field="remark" />
    </view>
  </view>

  <view class="footer">
    <button class="save-btn" bindtap="onSave" disabled="{{saving || selectedItems.length === 0}}">
      {{saving ? '入库中...' : '确认入库'}}
    </button>
  </view>
</view>
