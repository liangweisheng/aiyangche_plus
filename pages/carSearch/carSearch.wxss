/* pages/carSearch/carSearch.wxss */
/* 商用SaaS风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
  padding-bottom: 24rpx;
}

/* 品牌头部 */
.brand-header {
  padding: 56rpx 40rpx 40rpx;
  text-align: center;
}

.brand-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin-bottom: 8rpx;
}

.brand-subtitle {
  display: block;
  font-size: 24rpx;
  color: #999;
  font-weight: 400;
}

/* 输入区域 */
.input-section {
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #fff;
  border: 2rpx solid transparent;
  border-radius: 24rpx;
  padding: 0 28rpx;
  height: 112rpx;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.08);
  transition: all 0.3s ease;
}

.input-wrapper.focused {
  border-color: #1677ff;
  box-shadow: 0 8rpx 40rpx rgba(22, 119, 255, 0.15);
}

.input-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.plate-input {
  flex: 1;
  height: 112rpx;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 4rpx;
}

.plate-display {
  flex: 1;
  height: 112rpx;
  display: flex;
  align-items: center;
  font-size: 36rpx;
  font-weight: 600;
  color: #333;
  letter-spacing: 4rpx;
}

.plate-display.placeholder {
  font-size: 28rpx;
  font-weight: 400;
  color: #bbb;
  letter-spacing: 0;
}

.input-placeholder {
  font-size: 28rpx;
  font-weight: 400;
  color: #bbb;
  letter-spacing: 0;
}

.clear-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f0f0f0;
}

.clear-icon {
  font-size: 24rpx;
  color: #999;
}

.input-hint {
  display: block;
  font-size: 22rpx;
  color: #bbb;
  padding: 12rpx 12rpx 0;
  text-align: center;
}

/* 最近新增车辆 */
.recent-section {
  padding: 0 32rpx;
  margin-bottom: 28rpx;
}

.recent-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8rpx 0 16rpx;
}

.recent-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #999;
}

.recent-count {
  font-size: 22rpx;
  color: #ccc;
}

.recent-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx 24rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.recent-item:active {
  background: #f8f9ff;
}

.recent-plate {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  letter-spacing: 2rpx;
  margin-bottom: 4rpx;
}

.recent-info {
  font-size: 20rpx;
  color: #bbb;
}

/* 操作按钮 */
.btn-section {
  display: flex;
  gap: 20rpx;
  padding: 0 32rpx;
  margin-bottom: 32rpx;
}

.btn {
  flex: 1;
  height: 104rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 24rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 4rpx;
  box-shadow: 0 6rpx 24rpx rgba(0, 0, 0, 0.06);
}

.btn-search {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.35);
}

.btn-search:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-add {
  background: #fff;
  color: #1677ff;
  border: 2rpx solid #1677ff;
}

.btn-add.full {
  flex: none;
  width: 100%;
}

.btn-add:active {
  background: rgba(22, 119, 255, 0.04);
}

/* 搜索结果区域 */
.result-section {
  padding: 0 32rpx;
}

.section-header {
  padding: 8rpx 0 16rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #999;
}

/* 结果列表 */
.result-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.result-card:active {
  background: #fafafa;
  transform: scale(0.99);
}

.card-left {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.result-plate {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 8rpx;
  letter-spacing: 2rpx;
}

.result-type {
  font-size: 24rpx;
  color: #999;
}

.card-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.result-tags {
  display: flex;
  gap: 8rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
}

.tag.color {
  background: rgba(22, 119, 255, 0.08);
  color: #1677ff;
}

.tag.mileage {
  background: rgba(82, 196, 26, 0.08);
  color: #52c41a;
}

.arrow {
  font-size: 36rpx;
  color: #ccc;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.4;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #999;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 40rpx;
}

.empty-add-btn {
  width: 260rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 38rpx;
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(22, 119, 255, 0.3);
}

.empty-add-btn:active {
  transform: scale(0.97);
  opacity: 0.9;
}

/* 骨架屏 */
.skeleton-section {
  padding: 0 32rpx;
}

.skeleton-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.skeleton-line {
  height: 28rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #f5f5f5 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
}

.skeleton-plate {
  width: 180rpx;
  margin-bottom: 16rpx;
}

.skeleton-type {
  width: 280rpx;
  margin-bottom: 12rpx;
}

.skeleton-tag {
  width: 120rpx;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}
