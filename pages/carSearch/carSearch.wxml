<!-- 车牌搜索页面 - 商用SaaS风格 -->
<wxs src="../../utils/maskPlate.wxs" module="mask" />
<view class="container">

  <!-- 品牌标题 -->
  <view class="brand-header">
    <text class="brand-title">AI养车</text>
    <text class="brand-subtitle">门店智慧管理系统</text>
  </view>

  <!-- 输入区域 -->
  <view class="input-section">
    <view class="input-wrapper">
      <text class="input-icon">🚗</text>
      <input
        class="plate-input"
        type="text"
        maxlength="10"
        placeholder="请输入车牌号或手机号"
        placeholder-class="input-placeholder"
        value="{{plateNumber}}"
        bindinput="onPlateInput"
        confirm-type="search"
        bindconfirm="onSearch"
      />
      <view class="clear-btn" wx:if="{{plateNumber}}" bindtap="onClearInput">
        <text class="clear-icon">✕</text>
      </view>
    </view>
    <text class="input-hint">输入3位以上自动搜索车牌号或手机号</text>
  </view>

  <!-- 最近新增车辆 -->
  <view class="recent-section" wx:if="{{recentCars.length > 0 && !searchList.length && !loading}}">
    <view class="recent-header">
      <text class="recent-title">最近新增车辆</text>
      <text class="recent-count">共{{recentCars.length}}辆</text>
    </view>
    <view class="recent-list">
      <view class="recent-item" wx:for="{{recentCars}}" wx:key="_id" data-plate="{{item.plate}}" bindtap="onRecentTap">
        <text class="recent-plate">{{mask.maskPlate(item.plate)}}</text>
        <text class="recent-info">{{item.carType || ''}} {{item.color || ''}}</text>
      </view>
    </view>
  </view>

  <!-- 操作按钮：仅在无输入且无搜索结果时显示新增 -->
  <view class="btn-section" wx:if="{{!plateNumber && !searchList.length && !isEmpty}}">
    <view class="btn btn-add full" bindtap="onAddCar">
      <text class="btn-text">新增车辆</text>
    </view>
  </view>

  <!-- 搜索结果 -->
  <view class="result-section" wx:if="{{plateNumber.length >= 3}}">
    <view class="section-header" wx:if="{{!loading && searchList.length > 0}}">
      <text class="section-title">搜索结果 ({{searchList.length}})</text>
    </view>

    <!-- 结果列表 -->
    <view class="result-list" wx:if="{{searchList.length > 0}}">
      <view
        class="result-card"
        wx:for="{{searchList}}"
        wx:key="_id"
        data-id="{{item._id}}"
        data-plate="{{item.plate}}"
        bindtap="onResultTap"
      >
        <view class="card-left">
          <text class="result-plate">{{mask.maskPlate(item.plate)}}</text>
          <text class="result-type">{{item.carType || '未填写车型'}}</text>
        </view>
        <view class="card-right">
          <view class="result-tags">
            <view class="tag color" wx:if="{{item.color}}">{{item.color}}</view>
            <view class="tag mileage" wx:if="{{item.mileage}}">{{item.mileage}}km</view>
          </view>
          <text class="arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 空状态 → 引导新增 -->
    <view class="empty-state" wx:if="{{!loading && isEmpty}}">
      <text class="empty-icon">🔍</text>
      <text class="empty-text">未找到匹配车辆</text>
      <text class="empty-hint">请检查输入或新增车辆档案</text>
      <view class="empty-add-btn" bindtap="onAddCar">
        <text>新增车辆</text>
      </view>
    </view>

    <!-- 加载骨架 -->
    <view class="skeleton-section" wx:if="{{loading}}">
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-plate"></view>
        <view class="skeleton-line skeleton-type"></view>
        <view class="skeleton-line skeleton-tag"></view>
      </view>
      <view class="skeleton-card">
        <view class="skeleton-line skeleton-plate"></view>
        <view class="skeleton-line skeleton-type"></view>
        <view class="skeleton-line skeleton-tag"></view>
      </view>
    </view>
  </view>

</view>
