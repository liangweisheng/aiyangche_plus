/* pages/monthlyReport/monthlyReport.wxss */

page {
  background-color: #f5f6fa;
}

.container {
  min-height: 100vh;
  padding-bottom: 40rpx;
}

/* ====== 顶部导航 ====== */
.nav-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background-color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 1rpx solid #eee;
}

.nav-back {
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.nav-back-icon {
  font-size: 28rpx;
  color: #333;
}

.nav-back-text {
  font-size: 26rpx;
  color: #1677ff;
  margin-left: 4rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
  text-align: center;
}

.month-switcher {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.month-tab {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
  transition: all .2s;
}

.month-tab.active {
  color: #fff;
  background: #1677ff;
  font-weight: 600;
}

/* ====== 卡片通用 ====== */
.card {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

/* ====== 加载态 ====== */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #e6e6e6;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin .8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #999;
  font-size: 28rpx;
}

/* ====== 无数据态 ====== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  line-height: 1.6;
}

/* ====== 健康评分 ====== */
.score-section {
  text-align: center;
}

.score-header {
  margin-bottom: 16rpx;
}

.score-label {
  font-size: 26rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 72rpx;
  font-weight: 700;
  font-family: DIN Alternate, -apple-system, sans-serif;
}

.score-value.excellent { color: #52c41a; }
.score-value.good { color: #1677ff; }
.score-value.warning { color: #faad14; }
.score-value.critical { color: #ff4d4f; }

.score-unit {
  font-size: 28rpx;
  font-weight: 400;
  margin-left: 4rpx;
}

.score-level-tag {
  display: inline-block;
  font-size: 22rpx;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 24rpx;
}

.score-level-tag.excellent { background: #f6ffed; color: #52c41a; border: 1rpx solid #b7eb8f; }
.score-level-tag.good { background: #e6f7ff; color: #1677ff; border: 1rpx solid #91d5ff; }
.score-level-tag.warning { background: #fffbe6; color: #faad14; border: 1rpx solid #ffe58f; }
.score-level-tag.critical { background: #fff2f0; color: #ff4d4f; border: 1rpx solid #ffccc7; }

/* ====== 经营概览 ====== */
.section-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.overview-item {
  background: #fafafa;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
}

.overview-label {
  font-size: 22rpx;
  color: #999;
  display: block;
  margin-bottom: 8rpx;
}

.overview-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  font-family: DIN Alternate, -apple-system, sans-serif;
}

.overview-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #999;
  margin-left: 4rpx;
}

.overview-change {
  font-size: 20rpx;
  margin-top: 6rpx;
  display: block;
}
.overview-change.up { color: #52c41a; }
.overview-change.down { color: #ff4d4f; }
.overview-change.stable { color: #999; }

/* Phase 3: 客单价趋势标签 */
.overview-ticket-trend {
  font-size: 20rpx;
  margin-top: 6rpx;
  display: block;
}
.overview-ticket-trend.up { color: #52c41a; }
.overview-ticket-trend.down { color: #ff4d4f; }

/* ====== 指标进度条（Phase 3 新增） ====== */
.metrics-bars {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
}

.metric-bar-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.metric-bar-row:last-child {
  margin-bottom: 0;
}

.metric-bar-label {
  width: 130rpx;
  font-size: 23rpx;
  color: #666;
  flex-shrink: 0;
}

.metric-bar-track {
  flex: 1;
  height: 16rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-right: 16rpx;
}

.metric-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width .5s ease-out;
  min-width: 4rpx;
}
.metric-bar-fill.green { background: linear-gradient(90deg, #95de64, #52c41a); }
.metric-bar-fill.blue { background: linear-gradient(90deg, #69c0ff, #1677ff); }
.metric-bar-fill.orange { background: linear-gradient(90deg, #ffc53d, #faad14); }
.metric-bar-fill.purple { background: linear-gradient(90deg, #b37feb, #722ed1); }

.metric-bar-val {
  width: 70rpx;
  font-size: 22rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  flex-shrink: 0;
}

/* 同规模参考范围 */
.benchmark-ref {
  margin-top: 20rpx;
  padding: 16rpx 20rpx;
  background: #fafafa;
  border-radius: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.benchmark-label {
  font-size: 22rpx;
  color: #999;
}

.benchmark-values {
  font-size: 23rpx;
  color: #666;
  line-height: 1.5;
}

/* ====== 诊断建议（Phase 3 增强） ====== */
.diag-count {
  font-size: 22rpx;
  color: #999;
}

.diagnosis-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.diagnosis-item {
  border-radius: 12rpx;
  overflow: hidden;
  transition: all .25s ease;
}

.diagnosis-item.warning { border-left: 6rpx solid #faad14; }
.diagnosis-item.info { border-left: 6rpx solid #1677ff; }
.diagnosis-item.success { border-left: 6rpx solid #52c41a; }

/* 折叠头部 */
.diag-header {
  display: flex;
  align-items: flex-start;
  padding: 20rpx 20rpx;
  background: #fafafa;
  cursor: pointer;
}

.diagnosis-item.expanded .diag-header {
  border-bottom: 1rpx solid rgba(0,0,0,0.05);
  background: #fff;
}

.diagnosis-item.warning .diag-header { background: #fffbe6; }
.diagnosis-item.warning.expanded .diag-header { background: #fff9e6; }

.diagnosis-item.info .diag-header { background: #e6f7ff; }
.diagnosis-item.info.expanded .diag-header { background: #f0f8ff; }

.diagnosis-item.success .diag-header { background: #f6ffed; }
.diagnosis-item.success.expanded .diag-header { background: #fbfff5; }

.diag-icon {
  font-size: 32rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
  margin-top: 2rpx;
}

.diag-header-body {
  flex: 1;
  min-width: 0;
}

.diag-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.diag-detail-brief {
  font-size: 24rpx;
  color: #666;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 展开箭头 */
.diag-arrow {
  font-size: 30rpx;
  color: #bbb;
  flex-shrink: 0;
  margin-left: 12rpx;
  transition: transform .25s ease;
  line-height: 1;
  padding-top: 4rpx;
}

.diag-arrow.rotated {
  transform: rotate(90deg);
}

/* 展开内容区 */
.diag-expanded-content {
  padding: 20rpx 20rpx 20rpx 60rpx;
  animation: slideDown .2s ease-out;
}

@keyframes slideDown {
  from { opacity: 0; max-height: 0; }
  to   { opacity: 1; max-height: 400rpx; }
}

.suggestions-block {
  margin-bottom: 16rpx;
}

.suggestions-label {
  font-size: 24rpx;
  color: #1677ff;
  font-weight: 600;
  display: block;
  margin-bottom: 12rpx;
}

.suggestion-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 10rpx;
}

.suggestion-item:last-child {
  margin-bottom: 0;
}

.suggestion-dot {
  color: #1677ff;
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
  line-height: 1.4;
}

.suggestion-text {
  font-size: 24rpx;
  color: #555;
  line-height: 1.55;
  flex: 1;
}

/* 单条建议文本样式（兼容云函数返回的字符串格式） */
.suggestion-text-single {
  font-size: 26rpx;
  color: #555;
  line-height: 1.7;
  padding: 16rpx 24rpx;
  background: #f8f9fa;
  border-radius: 8rpx;
  display: block;
}

/* 查看案例按钮 */
.case-btn-area {
  margin-top: 12rpx;
}

.case-btn-full {
  display: inline-block;
  font-size: 24rpx;
  color: #1677ff;
  padding: 10rpx 28rpx;
  background: #e6f7ff;
  border-radius: 20rpx;
  font-weight: 500;
}

/* ====== Phase 4: 低数据提示 ====== */
.low-data-hint {
  padding: 16rpx 20rpx;
  background: #fffbe6;
  border: 1rpx solid #ffe58f;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}

.low-data-hint-text {
  font-size: 23rpx;
  color: #d48806;
  line-height: 1.5;
}

/* ====== Phase 4: 无诊断提示 ====== */
.no-diagnosis {
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  text-align: center;
}

.no-diag-icon {
  font-size: 56rpx;
  display: block;
  margin-bottom: 16rpx;
}

.no-diag-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.no-diag-hint {
  font-size: 24rpx;
  color: #999;
}
