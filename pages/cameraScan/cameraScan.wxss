/* pages/cameraScan/cameraScan.wxss */
/* 全屏拍照OCR扫描页面 - 蒙层镂空效果 */

/* ===== 页面基础 ===== */
.ocr-page {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  overflow: hidden;
  background: #000;
}

/* ===== 相机层 ===== */
.camera {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* ===== 相机加载态 ===== */
.camera-loading {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid rgba(255,255,255,0.2);
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: rgba(255,255,255,0.6);
}

/* ===== 相机失败降级 ===== */
.fallback-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1a1a1a;
}

.fallback-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx;
}

.fallback-icon-view {
  font-size: 100rpx;
  margin-bottom: 24rpx;
}

.fallback-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.fallback-desc {
  font-size: 26rpx;
  color: rgba(255,255,255,0.5);
  text-align: center;
  margin-bottom: 48rpx;
}

.fallback-btn {
  width: 400rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: #1677ff;
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin-bottom: 24rpx;
}

.fallback-btn:active {
  background: #0958d9;
}

.fallback-cancel {
  padding: 20rpx 40rpx;
  color: rgba(255,255,255,0.5);
  font-size: 28rpx;
}

/* ===== 遮罩容器 ===== */
.mask-container {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
}

/* ===== 顶部遮罩 ===== */
.mask-top {
  background: rgba(0, 0, 0, 0.55);
  padding-bottom: 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 导航栏 */
.nav-bar {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 80rpx 30rpx 0;
  box-sizing: border-box;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 56rpx;
  color: #fff;
  line-height: 1;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.nav-placeholder {
  width: 60rpx;
}

/* 提示文字 */
.tip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 20rpx;
  letter-spacing: 2rpx;
}

/* ===== 中间区域 ===== */
.mask-middle {
  display: flex;
  height: 300rpx;
  flex-shrink: 0;
}

/* 左右遮罩 */
.mask-side {
  width: 80rpx;
  background: rgba(0, 0, 0, 0.55);
  flex-shrink: 0;
}
.mask-side.left {
  border-right: none;
}
.mask-side.right {
  border-left: none;
}

/* ===== 扫描框 ===== */
.scan-box {
  flex: 1;
  position: relative;
}

/* 扫描框四角装饰 */
.corner {
  position: absolute;
  width: 36rpx;
  height: 36rpx;
  border-color: #00D4FF;
  border-style: solid;
  z-index: 2;
}
.corner-tl {
  top: 8rpx;
  left: 8rpx;
  border-width: 6rpx 0 0 6rpx;
  border-top-left-radius: 6rpx;
}
.corner-tr {
  top: 8rpx;
  right: 8rpx;
  border-width: 6rpx 6rpx 0 0;
  border-top-right-radius: 6rpx;
}
.corner-bl {
  bottom: 8rpx;
  left: 8rpx;
  border-width: 0 0 6rpx 6rpx;
  border-bottom-left-radius: 6rpx;
}
.corner-br {
  bottom: 8rpx;
  right: 8rpx;
  border-width: 0 6rpx 6rpx 0;
  border-bottom-right-radius: 6rpx;
}

/* 扫描线动画 */
.scan-line {
  position: absolute;
  left: 8rpx;
  right: 8rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #00D4FF, transparent);
  top: 10%;
  animation: scanMove 2.5s ease-in-out infinite;
  opacity: 0.8;
}

@keyframes scanMove {
  0%, 100% { top: 10%; }
  50% { top: 85%; }
}

/* ===== 底部遮罩 ===== */
.mask-bottom {
  flex: 1;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0 40rpx;
  box-sizing: border-box;
}

/* 手动输入链接 */
.manual-input {
  padding: 16rpx 32rpx;
  margin-bottom: 20rpx;
}

.manual-input text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  text-decoration: underline;
  text-underline-offset: 4rpx;
  text-decoration-color: rgba(255, 255, 255, 0.3);
}

.manual-input:active {
  opacity: 0.6;
}

/* 底部控制按钮行 */
.bottom-controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 80rpx;
  width: 100%;
  padding: 0 60rpx;
  box-sizing: border-box;
  position: absolute;
  bottom: 120rpx;
  left: 0;
}

/* 功能按钮（补光/相册） */
.bottom-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.btn-icon-circle {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
}

.btn-icon-text {
  font-size: 44rpx;
}

.btn-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.bottom-btn:active .btn-icon-circle {
  background: rgba(255, 255, 255, 0.25);
}

/* ===== 拍照按钮 ===== */
.shutter-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.shutter-outer {
  width: 136rpx;
  height: 136rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 0 20rpx rgba(0, 0, 0, 0.3);
}

.shutter-inner {
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: #fff;
  transition: transform 0.15s;
}

.shutter-btn:active .shutter-inner {
  transform: scale(0.9);
}
