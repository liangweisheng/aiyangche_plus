/* 营收报表页样式 */

/* 游客模式横幅 */
.guest-banner {
  background: linear-gradient(135deg, #faad14 0%, #ffc53d 100%);
  padding: 16rpx 32rpx;
  text-align: center;
}

.guest-banner-text {
  font-size: 26rpx;
  color: #fff;
  font-weight: 600;
}

.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 200rpx;
}

/* 未注册引导 */
.guide-section {
  padding: 60rpx 32rpx;
  display: flex;
  justify-content: center;
}

.guide-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  width: 100%;
}

.guide-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.guide-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 16rpx;
  display: block;
}

.guide-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  display: block;
  line-height: 1.6;
}

.guide-btn {
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 48rpx;
  padding: 20rpx 60rpx;
  font-size: 30rpx;
  font-weight: 600;
}

/* 日期范围切换 */
.date-tabs {
  display: flex;
  margin: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 8rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.date-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 12rpx;
  transition: all 0.2s;
}

.date-tab.active {
  background: #1677ff;
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(22, 119, 255, 0.3);
}

/* 月份/年份选择器行 */
.picker-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 24rpx;
  padding: 16rpx 0;
  gap: 32rpx;
}

.picker-arrow {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.picker-arrow:active {
  background: #f0f0f0;
}

.picker-arrow-text {
  font-size: 40rpx;
  color: #1677ff;
  font-weight: 300;
  line-height: 1;
}

.picker-arrow.picker-disabled {
  opacity: 0.25;
  pointer-events: none;
}

.picker-arrow.picker-disabled .picker-arrow-text {
  color: #999;
}

.picker-label {
  font-size: 32rpx;
  font-weight: 700;
  color: #1a1a1a;
  min-width: 200rpx;
  text-align: center;
}

/* 汇总卡片 */
.summary-section {
  margin: 24rpx;
}

.summary-row {
  display: flex;
  gap: 16rpx;
}

.summary-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 20rpx;
  display: flex;
  flex-direction: column;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.summary-card .summary-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.summary-card .summary-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.summary-card .summary-unit {
  font-size: 20rpx;
  font-weight: 400;
  color: #999;
}

.summary-card .summary-sub {
  font-size: 20rpx;
  color: #bbb;
}

.summary-card.blue { border-left: 6rpx solid #1677ff; }
.summary-card.green { border-left: 6rpx solid #52c41a; }
.summary-card.orange { border-left: 6rpx solid #fa8c16; }

.summary-card.blue .summary-value { color: #1677ff; }
.summary-card.green .summary-value { color: #52c41a; }
.summary-card.orange .summary-value { color: #fa8c16; }

/* 通用区块 */
.chart-section,
.payment-section,
.service-section,
.order-list-section,
.customer-section {
  margin: 24rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.section-sub {
  font-size: 24rpx;
  color: #999;
}

/* 趋势图 */
.chart-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.chart-area {
  height: 400rpx;
  position: relative;
}

.chart-grid {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 60rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  pointer-events: none;
}

.grid-line {
  height: 2rpx;
  background: #f0f0f0;
}

.chart-bars {
  height: 100%;
  display: flex;
  align-items: stretch;
  padding-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.chart-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 0;
}

.bar-tip {
  font-size: 18rpx;
  color: #1677ff;
  white-space: nowrap;
  flex-shrink: 0;
  line-height: 28rpx;
  margin-bottom: 4rpx;
}

.chart-bar-wrap {
  flex: 1;
  width: 60%;
  max-width: 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
  min-height: 0;
}

.chart-bar {
  width: 100%;
  background: linear-gradient(180deg, #1677ff 0%, #69b1ff 100%);
  border-radius: 6rpx 6rpx 0 0;
  min-height: 4rpx;
}

.bar-label {
  font-size: 20rpx;
  color: #999;
  white-space: nowrap;
  margin-top: 16rpx;
  flex-shrink: 0;
}

.chart-empty {
  height: 300rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 支付方式 - 横向双栏布局 */
.payment-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: row;
}

.payment-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  flex: 1;
  border-bottom: none;
  border-right: 2rpx solid #f5f5f5;
}

.payment-item:last-child {
  border-right: none;
}

.payment-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.payment-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 12rpx;
}

.payment-icon.cash { background: #fff7e6; }
.payment-icon.credit { background: #fff1f0; }
.payment-icon.wechat { background: #f6ffed; }

.payment-info {
  display: flex;
  flex-direction: column;
}

.payment-name {
  font-size: 26rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.payment-amount {
  font-size: 24rpx;
  color: #999;
}

.payment-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  margin-left: 16rpx;
  min-width: 140rpx;
}

.payment-percent {
  font-size: 24rpx;
  font-weight: 600;
  color: #1677ff;
  margin-bottom: 6rpx;
}

.payment-bar-bg {
  width: 100rpx;
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.payment-bar {
  height: 100%;
  background: #1677ff;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* 服务项目排行 */
.service-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.service-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.service-item:last-child {
  border-bottom: none;
}

.service-rank {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #999;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.service-rank.top {
  background: linear-gradient(135deg, #ffd666 0%, #ffc53d 100%);
  color: #fff;
}

.service-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.service-name {
  font-size: 28rpx;
  color: #1a1a1a;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.service-count {
  font-size: 22rpx;
  color: #999;
}

.service-revenue {
  font-size: 28rpx;
  font-weight: 700;
  color: #fa8c16;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 今日订单清单 */
.order-list-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.order-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.order-row:last-child {
  border-bottom: none;
}

.order-row-plate {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.plate-badge {
  font-size: 28rpx;
  font-weight: 700;
  color: #1a1a1a;
  background: #f0f5ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 2rpx solid #d6e4ff;
  margin-right: 14rpx;
  flex-shrink: 0;
  max-width: 240rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-row-status {
  font-size: 20rpx;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  background: #e6f4ff;
  color: #1677ff;
  flex-shrink: 0;
}

.order-row-status.done {
  background: #f6ffed;
  color: #52c41a;
}

.order-row-status.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.order-row-right {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.order-row-time {
  font-size: 22rpx;
  color: #999;
  margin-right: 20rpx;
}

.order-row-amount {
  font-size: 28rpx;
  font-weight: 700;
  color: #fa8c16;
}

/* 消费TOP20车主 */
.customer-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.customer-item {
  display: flex;
  align-items: center;
  padding: 24rpx 28rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.customer-item:last-child {
  border-bottom: none;
}

.customer-item:active {
  background: #f5f5f5;
}

.customer-rank {
  width: 44rpx;
  height: 44rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  color: #999;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.customer-rank.top {
  background: linear-gradient(135deg, #ff7875 0%, #ff4d4f 100%);
  color: #fff;
}

.customer-plate-area {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.customer-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.customer-count {
  font-size: 22rpx;
  color: #999;
}

.customer-total {
  font-size: 28rpx;
  font-weight: 700;
  color: #cf1322;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.customer-more {
  text-align: center;
  padding: 24rpx 0 12rpx;
  font-size: 24rpx;
  color: #1677ff;
}

.customer-more:active {
  opacity: 0.7;
}

/* 消费排行 - 已加载全部 */
.load-more-tip {
  text-align: center;
  padding: 32rpx 0 40rpx;
}

.load-more-tip-text {
  font-size: 24rpx;
  color: #bbb;
}

/* 缓存提示 */
.cache-tip-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 20rpx;
  margin: 16rpx 24rpx 0;
  background: #f0f7ff;
  border-radius: 8rpx;
}
.cache-tip-icon {
  font-size: 24rpx;
  margin-right: 6rpx;
  color: #6699cc;
}
.cache-tip-text {
  font-size: 22rpx;
  color: #6699cc;
}

/* 免费版高级报表限制提示卡片 */
.pro-limit-card {
  display: flex;
  align-items: center;
  margin: 32rpx 24rpx;
  padding: 36rpx 28rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.pro-limit-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fff7e6 0%, #ffe7ba 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.pro-limit-icon {
  font-size: 40rpx;
}

.pro-limit-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.pro-limit-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.pro-limit-desc {
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.pro-limit-btn {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 16rpx 36rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.pro-limit-btn:active {
  opacity: 0.85;
}

/* 加载状态 */
.g-loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255,255,255,0.85);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.g-loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e6f4ff;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: g-spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes g-spin {
  to { transform: rotate(360deg); }
}

.g-loading-text {
  font-size: 26rpx;
  color: #1677ff;
}

/* 空数据提示 */
.empty-report {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 60rpx;
  margin: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
}

.empty-report-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
}

.empty-report-text {
  font-size: 30rpx;
  color: #666;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-report-sub {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  line-height: 1.5;
}
