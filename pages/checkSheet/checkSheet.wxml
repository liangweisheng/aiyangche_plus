<!-- 电子查车单 - 商用SaaS风格 -->
<wxs src="../../utils/maskPlate.wxs" module="mask" />
<view class="container">

  <!-- 第一步：车牌搜索（未选车辆时显示） -->
  <view class="card search-card" wx:if="{{!carInfo}}">
    <view class="card-title">
      <text class="title-icon">🔍</text>
      搜索车辆
    </view>
    <view class="search-hint">请先输入车牌号，选择要检查的车辆</view>
    <view class="search-row">
      <input
        class="search-input"
        placeholder="请输入车牌号（3位自动搜索）"
        value="{{searchPlate}}"
        bindinput="onSearchPlateInput"
        confirm-type="search"
        bindconfirm="onSearchCar"
        focus="{{autoFocusSearch}}"
      />
      <view class="ocr-btn" bindtap="onScanPlate">
        <image class="ocr-icon" src="/images/camera.png" mode="aspectFit" />
      </view>
    </view>

    <!-- 模糊搜索下拉结果 -->
    <view class="dropdown-list" wx:if="{{searchResults.length > 0}}">
      <view class="dropdown-item" wx:for="{{searchResults}}" wx:key="_id"
        bindtap="onSelectCar" data-plate="{{item.plate}}">
        <text class="dropdown-plate">{{mask.maskPlate(item.plate)}}</text>
        <text class="dropdown-owner">{{item.ownerName || '未知车主'}}</text>
      </view>
    </view>

    <!-- 无结果提示 -->
    <view class="dropdown-empty" wx:if="{{searched && searchResults.length === 0}}">
      <text class="empty-text">未找到相关车辆</text>
    </view>

    <!-- 最近添加的车辆 -->
    <view class="recent-section" wx:if="{{recentCars.length > 0}}">
      <view class="recent-title">最近添加</view>
      <view class="recent-grid">
        <view class="recent-tag" wx:for="{{recentCars}}" wx:key="_id"
          data-plate="{{item.plate}}" bindtap="onRecentTap">
          <text class="recent-plate">{{mask.maskPlate(item.plate)}}</text>
          <text class="recent-owner" wx:if="{{item.ownerName}}">{{item.ownerName}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 车辆已选定：显示检查表单 -->
  <view wx:if="{{carInfo}}">

  <!-- 车辆信息卡片 -->
  <view class="vehicle-card" wx:if="{{carInfo}}">
    <view class="card-header">
      <text class="plate" bindtap="onPlateTap">{{plate}}</text>
      <view class="plate-actions-inline">
        <view class="action-btn-sm" bindtap="onViewHistory">
          <text>📋 历史查车单</text>
        </view>
      </view>
      <view class="badge">待检查</view>
    </view>
    <view class="card-body">
      <view class="info-row">
        <text class="label">车型</text>
        <text class="value">{{carInfo.carType || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="label">颜色</text>
        <text class="value">{{carInfo.color || '未填写'}}</text>
      </view>
      <view class="info-row">
        <text class="label">入库时间</text>
        <text class="value">{{carInfo.createTime}}</text>
      </view>
    </view>
  </view>

  <!-- 检查项目 -->
  <view class="check-section">
    <view class="section-title">检查项目</view>
    <view class="check-grid">
      <view class="check-card" wx:for="{{checkItems}}" wx:key="key">
        <view class="card-icon">{{item.icon}}</view>
        <view class="card-label-row">
          <text class="card-label">{{item.label}}</text>
          <view class="normal-check" bindtap="onToggleNormal" data-key="{{item.key}}">
            <view class="checkbox {{item.normal ? 'checked' : ''}}">
              <text class="check-mark" wx:if="{{item.normal}}">✓</text>
            </view>
            <text class="check-text">正常</text>
          </view>
        </view>
        <textarea
          class="check-input"
          placeholder="检查结果"
          placeholder-class="check-placeholder"
          value="{{form[item.key]}}"
          data-field="{{item.key}}"
          bindinput="onInput"
          maxlength="100"
        />
      </view>
    </view>
  </view>

  <!-- 问题描述 -->
  <view class="form-section">
    <view class="section-title">问题描述</view>
    <view class="form-card">
      <textarea
        class="textarea"
        placeholder="记录发现的问题..."
        placeholder-class="placeholder"
        value="{{form.issue}}"
        data-field="issue"
        bindinput="onInput"
        maxlength="200"
      />
    </view>
  </view>

  <!-- 维修建议 -->
  <view class="form-section">
    <view class="section-title">维修建议</view>
    <view class="form-card">
      <textarea
        class="textarea"
        placeholder="给出维修或保养建议..."
        placeholder-class="placeholder"
        value="{{form.suggestion}}"
        data-field="suggestion"
        bindinput="onInput"
        maxlength="200"
      />
    </view>
  </view>

  <!-- 客户签名（预留） -->
  <view class="sign-section disabled">
    <view class="section-title">客户签名</view>
    <view class="sign-card">
      <text class="sign-icon">✍️</text>
      <text class="sign-text">签名功能开发中</text>
    </view>
  </view>

  </view>

</view>

<!-- 底部操作栏（有车辆时才显示） -->
<view class="footer" wx:if="{{carInfo}}">
  <view class="btn-row">
    <view class="cancel-btn" catchtap="onCancel">
      <text class="cancel-text">取消</text>
    </view>
    <view class="save-btn" catchtap="onSave">
      <text class="btn-text">保存查车单</text>
    </view>
  </view>
</view>

<!-- 浮动首页按钮 -->
<view class="fab-home" bindtap="onGoHome">首页</view>
