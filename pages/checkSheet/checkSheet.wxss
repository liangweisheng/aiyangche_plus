/* pages/checkSheet/checkSheet.wxss */
/* 商用SaaS风格 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0f7ff 0%, #f5f7fa 100%);
  padding: 24rpx 24rpx 140rpx;
}

/* ======================== */
/* 车牌搜索卡片（无 plate 参数时） */
/* ======================== */

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #f0f0f0;
  display: flex;
  align-items: center;
}

.title-icon {
  margin-right: 12rpx;
  font-size: 36rpx;
}

.search-card {
  border-left: 6rpx solid #1677ff;
}

.search-hint {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 24rpx;
}

.search-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.search-input {
  flex: 1;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  background: #f5f7fa;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  box-sizing: border-box;
}

.search-input:focus {
  background: #fff;
  border-color: #1677ff;
}

/* 模糊搜索下拉 */
.dropdown-list {
  margin-top: 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  overflow: hidden;
  border: 2rpx solid #e0e0e0;
}

.dropdown-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  border-bottom: 1rpx solid #ebebeb;
}

.dropdown-item:last-child {
  border-bottom: none;
}

.dropdown-item:active {
  background: #e6f4ff;
}

.dropdown-plate {
  font-size: 30rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 2rpx;
}

.dropdown-owner {
  font-size: 24rpx;
  color: #666;
}

.dropdown-empty {
  margin-top: 16rpx;
  padding: 24rpx;
  text-align: center;
}

.dropdown-empty .empty-text {
  font-size: 26rpx;
  color: #ccc;
}

/* 最近添加 */
.recent-section {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f0f0f0;
}

.recent-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.recent-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.recent-tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #f0f5ff;
  border: 2rpx solid #d6e4ff;
  border-radius: 16rpx;
  min-width: 140rpx;
}

.recent-tag:active {
  background: #d6e4ff;
}

.recent-plate {
  font-size: 26rpx;
  font-weight: 700;
  color: #1677ff;
  letter-spacing: 1rpx;
}

.recent-owner {
  font-size: 20rpx;
  color: #999;
  margin-top: 4rpx;
}

/* ======================== */
/* 车辆信息卡片              */
/* ======================== */

/* 车辆信息卡片 */
.vehicle-card {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 28rpx;
  box-shadow: 0 12rpx 48rpx rgba(22, 119, 255, 0.25);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.2);
}

.plate {
  font-size: 48rpx;
  font-weight: 800;
  color: #fff;
  letter-spacing: 4rpx;
}

.plate:active {
  opacity: 0.7;
}

.plate-actions-inline {
  display: flex;
  gap: 12rpx;
}

.action-btn-sm {
  padding: 8rpx 18rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.action-btn-sm:active {
  opacity: 0.7;
}

.badge {
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.25);
  backdrop-filter: blur(8rpx);
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
}

.card-body {
  padding-top: 8rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.info-row .label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.info-row .value {
  font-size: 24rpx;
  color: #fff;
  font-weight: 500;
}

/* 分区标题 */
.section-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #999;
  margin-bottom: 20rpx;
  padding: 0 8rpx;
}

/* 检查项目 */
.check-section {
  margin-bottom: 28rpx;
}

.check-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.check-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.card-icon {
  font-size: 40rpx;
  margin-bottom: 12rpx;
}

.card-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.card-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.normal-check {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.checkbox {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #d9d9d9;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.checkbox.checked {
  background: #1677ff;
  border-color: #1677ff;
}

.check-mark {
  font-size: 20rpx;
  color: #fff;
  font-weight: 700;
}

.check-text {
  font-size: 22rpx;
  color: #666;
}

.check-input {
  width: 100%;
  min-height: 100rpx;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 22rpx;
  color: #333;
  line-height: 1.4;
  box-sizing: border-box;
}

.check-placeholder {
  color: #bbb;
}

/* 表单区域 */
.form-section {
  margin-bottom: 28rpx;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.textarea {
  width: 100%;
  min-height: 140rpx;
  background: #f7f8fa;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 26rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
}

.placeholder {
  color: #bbb;
}

/* 签名区域 */
.sign-section {
  margin-bottom: 28rpx;
}

.sign-section.disabled {
  opacity: 0.5;
}

.sign-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 60rpx;
  text-align: center;
  border: 2rpx dashed #e0e0e0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.sign-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.sign-text {
  display: block;
  font-size: 24rpx;
  color: #999;
}

/* 底部操作栏 */
.footer {
  position: fixed;
  z-index: 100;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.btn-row {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.cancel-btn {
  flex-shrink: 0;
  width: 160rpx;
  height: 104rpx;
  background: #f5f5f5;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn:active {
  background: #e8e8e8;
}

.cancel-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #666;
}

.save-btn {
  flex: 1;
  height: 104rpx;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(22, 119, 255, 0.35);
}

.save-btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
  letter-spacing: 4rpx;
}

/* 浮动首页按钮 */
.fab-home {
  position: fixed;
  right: 32rpx;
  bottom: 300rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  box-shadow: 0 8rpx 28rpx rgba(22, 119, 255, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.fab-home:active {
  opacity: 0.8;
  transform: scale(0.92);
}
