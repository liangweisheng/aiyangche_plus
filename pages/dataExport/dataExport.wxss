page { background: #f5f7fa; }

.container { padding: 32rpx; }

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 12rpx;
}

.page-desc {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 40rpx;
  line-height: 1.6;
}

.export-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.export-card:active { opacity: 0.85; }

.card-icon {
  width: 88rpx;
  height: 88rpx;
  background: #f0f7ff;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  flex-shrink: 0;
  margin-right: 24rpx;
}

.card-content {
  flex: 1;
  min-width: 0;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  line-height: 1.5;
}

.card-arrow {
  font-size: 36rpx;
  color: #ccc;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-box {
  width: 320rpx;
  padding: 48rpx 32rpx;
  background: #fff;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 6rpx solid #e8e8e8;
  border-top-color: #1677ff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.loading-text {
  font-size: 28rpx;
  color: #333;
}

/* 库存流水筛选弹窗遮罩 */
.stock-filter-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stock-filter-panel {
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 36rpx;
}

.stock-filter-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 36rpx;
}

.filter-section {
  margin-bottom: 32rpx;
}

.filter-label {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 16rpx;
  font-weight: 500;
}

/* 类型按钮组 */
.filter-type-group {
  display: flex;
  gap: 16rpx;
}

.filter-type-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.filter-type-btn.active {
  color: #1677ff;
  background: #e8f0ff;
  border-color: #1677ff;
  font-weight: 500;
}

/* 日期选择行 */
.filter-date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.filter-date-input {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  font-size: 26rpx;
  color: #bbb;
  background: #f5f5f5;
  border-radius: 12rpx;
  border: 2rpx solid transparent;
}

.filter-date-input.has-value {
  color: #333;
  border-color: #1677ff;
}

.filter-date-sep {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

/* 按钮区 */
.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 48rpx;
}

.filter-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 30rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.filter-btn.cancel {
  color: #666;
  background: #f5f5f5;
}

.filter-btn.confirm {
  color: #fff;
  background: #1677ff;
}
