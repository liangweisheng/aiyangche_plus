<view class="container">
  <view class="page-title">数据导出</view>
  <view class="page-desc">导出本门店的业务数据为Excel文件，通过微信发送给好友或文件传输助手</view>

  <!-- 导出分类卡片 -->
  <view class="export-card" bindtap="onExport" data-type="cars">
    <view class="card-icon">🚗</view>
    <view class="card-content">
      <text class="card-title">车辆信息清单</text>
      <text class="card-desc">导出所有车辆档案，含车型、车架号、保养/保险到期等信息</text>
    </view>
    <view class="card-arrow">›</view>
  </view>

  <view class="export-card" bindtap="onExport" data-type="members">
    <view class="card-icon">👥</view>
    <view class="card-content">
      <text class="card-title">会员权益清单</text>
      <text class="card-desc">导出所有会员信息及权益使用情况，自动计算剩余次数</text>
    </view>
    <view class="card-arrow">›</view>
  </view>

  <view class="export-card" bindtap="onExport" data-type="orders">
    <view class="card-icon">📋</view>
    <view class="card-content">
      <text class="card-title">订单明细清单</text>
      <text class="card-desc">导出所有工单明细，含服务项目、金额、支付方式、状态等</text>
    </view>
    <view class="card-arrow">›</view>
  </view>

  <view class="export-card" bindtap="onExport" data-type="stock_logs">
    <view class="card-icon">📦</view>
    <view class="card-content">
      <text class="card-title">库存明细清单</text>
      <text class="card-desc">导出所有出入库流水，含商品名称、规格、流水类型、数量、时间、操作人</text>
    </view>
    <view class="card-arrow">›</view>
  </view>

  <!-- 导出中遮罩 -->
  <view class="loading-mask" wx:if="{{exporting}}">
    <view class="loading-box">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>

  <!-- 库存流水筛选弹窗 -->
  <view class="stock-filter-mask" wx:if="{{showStockFilter}}">
    <view class="stock-filter-panel">
      <view class="stock-filter-title">库存流水筛选</view>

      <!-- 流水类型 -->
      <view class="filter-section">
        <view class="filter-label">流水类型</view>
        <view class="filter-type-group">
          <view class="filter-type-btn {{filterLogType === 'in' ? 'active' : ''}}" data-value="in" bindtap="onSelectLogType">入库</view>
          <view class="filter-type-btn {{filterLogType === 'out' ? 'active' : ''}}" data-value="out" bindtap="onSelectLogType">出库</view>
          <view class="filter-type-btn {{filterLogType === 'adjust' ? 'active' : ''}}" data-value="adjust" bindtap="onSelectLogType">调整</view>
        </view>
      </view>

      <!-- 时间范围 -->
      <view class="filter-section">
        <view class="filter-label">时间范围</view>
        <view class="filter-date-row">
          <picker mode="date" value="{{filterStartDate}}" start="2020-01-01" end="{{today}}" bindchange="onFilterStartDate">
            <view class="filter-date-input {{filterStartDate ? 'has-value' : ''}}">
              {{filterStartDate || '开始日期'}}
            </view>
          </picker>
          <text class="filter-date-sep">至</text>
          <picker mode="date" value="{{filterEndDate}}" start="2020-01-01" end="{{today}}" bindchange="onFilterEndDate">
            <view class="filter-date-input {{filterEndDate ? 'has-value' : ''}}">
              {{filterEndDate || '结束日期'}}
            </view>
          </picker>
        </view>
      </view>

      <!-- 按钮 -->
      <view class="filter-actions">
        <view class="filter-btn cancel" bindtap="onCancelFilter">取消</view>
        <view class="filter-btn confirm" bindtap="onConfirmFilter">确认导出</view>
      </view>
    </view>
  </view>
</view>
