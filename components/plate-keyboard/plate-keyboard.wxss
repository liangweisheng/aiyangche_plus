/* 车牌键盘样式 */
.plate-keyboard-mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1100;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
}

.keyboard-area {
  background: #f5f5f5;
  border-radius: 24rpx 24rpx 0 0;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 显示区 */
.display-area {
  padding: 24rpx 30rpx;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
}

.plate-box {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.cell {
  width: 64rpx;
  height: 80rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  background: #f9f9f9;
  margin-left: 6rpx;
}

.cell:first-child {
  margin-left: 0;
}

.cell.filled {
  border-color: #ccc;
}

.cell.active {
  border-color: #07c160;
  background: #e8f8ef;
}

.cell.energy.filled {
  border-color: #07c160;
  color: #07c160;
  background: #f0faf5;
}

.cell.energy.active {
  border-color: #07c160;
  background: #d4f5e0;
}

.dot {
  font-size: 40rpx;
  font-weight: bold;
  color: #999;
  margin: 0 6rpx;
}

/* 能源切换 */
.energy-switch {
  display: flex;
  justify-content: center;
  gap: 30rpx;
}

.switch-item {
  padding: 8rpx 30rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #999;
  background: #f5f5f5;
}

.switch-item.active {
  color: #fff;
  background: #07c160;
}

/* 键盘区域 */
.keys-area {
  padding: 16rpx 12rpx;
}

.keys-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.key-item {
  min-width: 56rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fff;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  box-shadow: 0 1rpx 2rpx rgba(0,0,0,0.08);
}

.key-item:active {
  background: #e0e0e0;
}

/* 省份键盘：10列 */
.province-grid .key-item {
  width: calc((100% - 72rpx) / 10);
}

/* 字母键盘：7列 */
.letter-grid .key-item {
  width: calc((100% - 36rpx) / 7);
}

/* 混合键盘：10列 */
.mix-grid .key-item {
  width: calc((100% - 72rpx) / 10);
}

/* 功能键 */
.func-row {
  display: flex;
  gap: 16rpx;
  margin-top: 4rpx;
}

.func-item {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.func-item.back {
  background: #ddd;
  color: #333;
  flex: 1.2;
}

.func-item.confirm {
  background: #07c160;
  color: #fff;
  flex: 1.5;
}

.func-item:active {
  opacity: 0.7;
}
