/* components/radar-chart/radar-chart.wxss */

.radar-wrapper {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 16rpx 0;
}

.radar-canvas {
  /* 尺寸由 inline style (rpx) 或 JS 强制设置控制 */
}

/* ========== 文本降级模式样式（APP端兜底）========== */
.radar-text-fallback {
  width: 100%;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
}

.rf-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
}

.rf-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.rf-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.rf-label {
  width: 80rpx;
  font-size: 26rpx;
  color: #666;
  flex-shrink: 0;
}

.rf-score {
  width: 70rpx;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  text-align: right;
}

.rf-bar {
  flex: 1;
  height: 14rpx;
  background: #f0f0f0;
  border-radius: 7rpx;
  overflow: hidden;
}

.rf-bar-fill {
  height: 100%;
  border-radius: 7rpx;
  transition: width 0.3s ease;
}

.rf-percent {
  font-size: 22rpx;
  color: #999;
  flex-shrink: 0;
  width: 80rpx;
}
