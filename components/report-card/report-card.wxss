/* components/report-card/report-card.wxss */

.report-card {
  position: relative;
  margin: 20rpx 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(22, 119, 255, 0.08);
  border: 1rpx solid rgba(22, 119, 255, 0.10);
}

/* 右上角红点 */
.red-dot {
  position: absolute;
  top: 16rpx;
  right: 20rpx;
  width: 16rpx;
  height: 16rpx;
  background: #ff4d4f;
  border-radius: 50%;
  z-index: 10;
  animation: dot-pulse 1.5s ease-in-out infinite;
}

@keyframes dot-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50% { opacity: 0.6; transform: scale(0.85); }
}

/* 无数据态 */
.card-empty {
  display: flex;
  align-items: center;
}

.empty-icon {
  font-size: 56rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.empty-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.empty-desc {
  font-size: 23rpx;
  color: #999;
}

.empty-action {
  font-size: 24rpx;
  color: #1677ff;
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 加载态 */
.card-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0;
}

.loading-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 有数据态 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-tag {
  font-size: 25rpx;
  color: #666;
  background: #f0f5ff;
  padding: 6rpx 18rpx;
  border-radius: 8rpx;
}

.score-block {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.score-num {
  font-size: 48rpx;
  font-weight: 700;
  font-family: DIN Alternate, -apple-system, sans-serif;
}
.score-num.excellent { color: #52c41a; }
.score-num.good { color: #1677ff; }
.score-num.warning { color: #faad14; }
.score-num.critical { color: #ff4d4f; }

.score-unit {
  font-size: 22rpx;
  color: #999;
}

.score-level {
  font-size: 21rpx;
  padding: 3rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}
.score-level.excellent { background: #f6ffed; color: #52c41a; }
.score-level.good { background: #e6f7ff; color: #1677ff; }
.score-level.warning { background: #fffbe6; color: #faad14; }
.score-level.critical { background: #fff2f0; color: #ff4d4f; }

/* 卡片内容行 */
.card-body {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.card-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.row-label {
  font-size: 24rpx;
  color: #999;
}

.row-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  font-family: DIN Alternate, -apple-system, sans-serif;
}

.row-unit {
  font-size: 20rpx;
  color: #999;
  font-weight: 400;
}

/* 底部操作 */
.card-footer {
  text-align: right;
  border-top: 1rpx solid #f0f0f0;
  padding-top: 16rpx;
  margin-top: 4rpx;
}

.footer-action {
  font-size: 24rpx;
  color: #1677ff;
}
